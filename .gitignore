# Python
__pycache__/
*.py[cod]
*.so
*.egg-info/
.ipynb_checkpoints/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*~

# LaTeX build artefacts
*.aux
*.bbl
*.blg
*.log
*.out
*.toc
*.synctex.gz
